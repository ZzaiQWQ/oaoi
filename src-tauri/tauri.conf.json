{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "oaoi",
  "version": "1.0.0",
  "identifier": "com.oaoi.launcher",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "oaoi - Minecraft 服务器启动器",
        "width": 854,
        "height": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "minWidth": 800,
        "minHeight": 550,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}