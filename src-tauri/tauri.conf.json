{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "oaoi",
  "version": "1.2.1",
  "identifier": "com.oaoi.launcher",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "node scripts/sync_dist.js --release",
    "beforeDevCommand": "node scripts/sync_dist.js"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "oaoi - Minecraft启动器",
        "width": 800,
        "height": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "minWidth": 400,
        "minHeight": 225,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' asset: http://asset.localhost https://launchercontent.mojang.com https://cdn.modrinth.com https://media.forgecdn.net https://mc-heads.net https://crafthead.net https://crafatar.com https://minotar.net data:; connect-src 'self' https: wss://xl.oaoi.cn http://localhost; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "publisher": "ZzaiQWQ",
    "homepage": "https://github.com/ZzaiQWQ/oaoi",
    "copyright": "Copyright (c) 2026 ZzaiQWQ. All Rights Reserved.",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
